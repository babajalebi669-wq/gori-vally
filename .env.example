# Copy this file to .env.local and fill in the values from your Supabase
# project (Settings -> API Keys). Never commit .env.local.
#
# Supabase renamed these keys in 2025/2026. On a project created today you'll
# see "Publishable key" and "Secret key" instead of "anon" / "service_role" —
# same roles under the hood, just new names and a new sb_publishable_.../
# sb_secret_... format instead of the old long JWT strings. Use:
#   NEXT_PUBLIC_SUPABASE_ANON_KEY  <- your Publishable key
#   SUPABASE_SERVICE_ROLE_KEY      <- your Secret key
# (If your project still shows the legacy names, anon -> ANON_KEY and
# service_role -> SERVICE_ROLE_KEY, exactly as before.)

# Public — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret — server-only, bypasses Row Level Security. Never prefix this with
# NEXT_PUBLIC_ and never import lib/supabase/admin.ts into a Client Component.
SUPABASE_SERVICE_ROLE_KEY=
